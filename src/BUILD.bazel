    deps = [
        ":solver",
        "@libtorch_macos_arm64//:torch",
    ],
    linkopts = ["-framework Accelerate"],
    visibility = ["//visibility:public"],
)

cc_library(
    name = "deep_cfr",
    srcs = ["deep_cfr.cc"],
    hdrs = ["deep_cfr.h"],
