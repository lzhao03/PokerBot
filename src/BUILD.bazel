cc_library(
    name = "neural_policy",
    srcs = ["neural_policy.cc"],
    hdrs = ["neural_policy.h"],
    copts = [
        "-DACCELERATE_NEW_LAPACK",
        "-Werror=return-type",
        "-Wswitch-enum",
        "-Wconversion",
        "-Wsign-conversion",
