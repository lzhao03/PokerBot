load("@rules_cc//cc:defs.bzl", "cc_binary", "cc_library")

CORE_COPTS = [
    "-fno-exceptions",
    "-Werror=return-type",
    "-Wswitch-enum",
    "-Wconversion",
    "-Wsign-conversion",
]

cc_library(
    name = "poker",
    srcs = [
        "hand_evaluator.cc",
        "poker.cc",
    ],
    hdrs = [
        "hand_evaluator.h",
        "poker.h",
    ],
    copts = CORE_COPTS,
    deps = [
        "@abseil-cpp//absl/container:inlined_vector",
        "@abseil-cpp//absl/status:status",
        "@abseil-cpp//absl/status:statusor",
    ],
    visibility = ["//visibility:public"],
)

cc_library(
    name = "bet_abstraction",
    srcs = ["bet_abstraction.cc"],
    hdrs = ["bet_abstraction.h"],
    copts = CORE_COPTS,
    deps = [
        ":poker",
        "@abseil-cpp//absl/container:inlined_vector",
    ],
    visibility = ["//visibility:public"],
)

cc_library(
    name = "card_canonicalization",
    srcs = ["card_canonicalization.cc"],
    hdrs = ["card_canonicalization.h"],
    copts = CORE_COPTS,
    deps = [":poker"],
    visibility = ["//visibility:public"],
)

cc_library(
